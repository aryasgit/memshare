# Memshare share.sh local config — copy this file to .share.env and edit.
#
# .share.env is gitignored. Use it for per-machine secrets and IDs.

# ── ngrok (recommended for a stable URL) ────────────────────────────
#
# One-time setup:
#   1. brew install ngrok
#   2. Sign up (free):  https://ngrok.com
#   3. Add your authtoken (one time):
#        ngrok config add-authtoken <YOUR_TOKEN>
#      Get it at https://dashboard.ngrok.com/get-started/your-authtoken
#   4. Claim a free static domain at
#        https://dashboard.ngrok.com/domains
#      You'll get something like   aryaman-memshare.ngrok-free.app
#   5. Paste the domain (without https://) below, and rename this file
#      to .share.env

# MEMSHARE_NGROK_DOMAIN=aryaman-memshare.ngrok-free.app

# ── port ────────────────────────────────────────────────────────────
# Override if 8787 is already in use.
# MEMSHARE_PORT=8787
